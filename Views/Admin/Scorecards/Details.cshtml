@model JobPortal.Services.Interfaces.ScorecardDetailDto

@{
    ViewData["Title"] = "Scorecard Details";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Scorecard Details</h2>
            <p class="text-muted mb-0">Scorecard #@Model.Id</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="text-end">
                <div class="small text-muted">Overall Average Score</div>
                <div class="fs-4 fw-semibold">@Model.AverageScore.ToString("0.0#")</div>
            </div>
            <a asp-action="EditScorecard" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edit</a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            @if (Model.Responses.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Facet</th>
                                <th>Score</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var response in Model.Responses)
                            {
                                <tr>
                                    <td>@response.FacetName</td>
                                    <td>@response.Score.ToString("0.0#")</td>
                                    <td>@(string.IsNullOrWhiteSpace(response.Notes) ? "-" : response.Notes)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">This scorecard has no responses yet.</p>
            }
        </div>
    </div>
</div>