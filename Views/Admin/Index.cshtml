@model IEnumerable<JobPortal.Models.Job>

@{
    ViewData["Title"] = "Admin Dashboard - Manage Jobs";
}

<div class="container-fluid py-5">
    <div class="row mb-5">
        <div class="col-md-6">
            <h1 class="fw-bold"><i class="fas fa-briefcase me-3"></i>Manage Jobs</h1>
            <p class="text-muted">@Model.Count() job posting(s) active</p>
        </div>
        <div class="col-md-6 text-end">
            <a asp-controller="Admin" asp-action="Applications" class="btn btn-info btn-lg me-2"><i class="fas fa-file-alt me-2"></i>View Applications</a>
            <a asp-controller="Admin" asp-action="Create" class="btn btn-success btn-lg"><i class="fas fa-plus me-2"></i>Post New Job</a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th><i class="fas fa-briefcase me-2"></i>Job Title</th>
                            <th><i class="fas fa-align-left me-2"></i>Description</th>
                            <th class="text-center"><i class="fas fa-cog me-2"></i>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in Model)
                        {
                            <tr>
                                <td>
                                    <a asp-action="JobDetail" asp-route-id="@job.Id" class="text-decoration-none" style="color: #1E1765; font-size: 1.05rem; font-weight: 600;">
                                        <strong>@Html.DisplayFor(model => job.Title)</strong>
                                    </a>
                                    <br />
                                    <small class="badge badge-primary">ID: @job.Id</small>
                                </td>
                                <td>
                                    <small class="text-muted">
                                        @{
                                            var desc = job.Description;
                                            if (desc?.Length > 80)
                                            {
                                                @Html.Raw(desc.Substring(0, 80) + "...")
                                            }
                                            else
                                            {
                                                @desc
                                            }
                                        }
                                    </small>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="JobDetail" asp-route-id="@job.Id" class="btn btn-sm btn-outline-primary" title="View Details"><i class="fas fa-chart-bar"></i></a>
                                        <a asp-action="Edit" asp-route-id="@job.Id" class="btn btn-sm btn-outline-warning" title="Edit"><i class="fas fa-edit"></i></a>
                                        <a asp-action="Delete" asp-route-id="@job.Id" class="btn btn-sm btn-outline-danger" title="Delete"><i class="fas fa-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body text-center py-5">
                <i class="fas fa-briefcase fa-5x mb-3" style="color: #ddd;"></i>
                <h5 class="fw-bold mt-3">No Jobs Posted Yet</h5>
                <p class="text-muted mb-4">Start by creating your first job posting to attract top talent.</p>
                <a asp-controller="Admin" asp-action="Create" class="btn btn-success btn-lg"><i class="fas fa-plus me-2"></i>Post Your First Job</a>
            </div>
        </div>
    }
</div>
