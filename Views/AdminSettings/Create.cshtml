@{
    ViewData["Title"] = "Create Facet";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Create Scorecard Facet</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label for="name" class="form-label fw-bold">Name</label>
                            <input id="name" name="name" class="form-control" />
                            @Html.ValidationMessage("name", null, new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            <label for="displayOrder" class="form-label fw-bold">Display Order</label>
                            <input id="displayOrder" name="displayOrder" class="form-control" type="number" value="1" />
                            @Html.ValidationMessage("displayOrder", null, new { @class = "text-danger small" })
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-success">Create</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}