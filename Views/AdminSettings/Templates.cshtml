@model IEnumerable<JobPortal.Models.ScorecardTemplate>

@{
    ViewData["Title"] = "Settings - Scorecard Templates";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1">Scorecard Templates</h1>
            <p class="text-muted mb-0">Manage scorecard template names.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">Back to Facets</a>
            <a asp-action="CreateTemplate" class="btn btn-success">New Template</a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var template in Model)
                        {
                            <tr>
                                <td>@template.Name</td>
                                <td class="text-center">
                                    <a asp-action="EditTemplate" asp-route-id="@template.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <a asp-action="EditTemplateFacets" asp-route-templateId="@template.Id" class="btn btn-sm btn-outline-secondary">Edit Facets</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="text-center text-muted py-4">No templates configured.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
