<!DOCTYPE html>
@{
    var _fullName = User.Identity?.Name ?? "";
    var _nameParts = _fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
    var _initials = _nameParts.Length >= 2
        ? $"{_nameParts[0][0]}{_nameParts[^1][0]}".ToUpper()
        : (_nameParts.Length == 1 ? _nameParts[0][0].ToString().ToUpper() : "U");
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WiseRecruiter</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/branding.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/JobPortal.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark wr-navbar border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/image_a576bc.png" alt="WiseTech Global" height="30"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='inline'" />
                    <span style="display:none"><i class="fas fa-briefcase me-2"></i>WiseTech Global</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @{
                            var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                            var isAdminNavigation = currentController == "Admin" || currentController == "AdminSettings" || currentController == "RecommendationAdmin";
                        }
                        @if (isAdminNavigation)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Index">
                                    <i class="fas fa-briefcase me-1"></i>Jobs
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Candidates">
                                    <i class="fas fa-users me-1"></i>Candidates
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Analytics">
                                    <i class="fas fa-chart-bar me-1"></i>Analytics
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="settingsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-sliders-h me-1"></i>Settings
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="settingsDropdown">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Admin" asp-action="Settings"><i class="fas fa-cog me-2"></i>Configuration</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Email" asp-action="EmailTemplates"><i class="fas fa-envelope me-2"></i>Email Library</a></li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="AdminSettings" asp-action="ManageTeam"><i class="fas fa-users-cog me-2"></i>Manage Team</a></li>
                                    }
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Job" asp-action="Index">Browse Jobs</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Applications" asp-action="Index">My Applications</a>
                            </li>
                        }
                        @if (!isAdminNavigation)
                        {
                            <li class="nav-item ms-auto">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="fas fa-sign-in-alt me-1"></i>Admin Login
                                </a>
                            </li>
                        }
                    </ul>
                    @if (isAdminNavigation)
                    {
                        <form asp-action="SearchCandidates" asp-controller="Admin" method="get" class="d-flex ms-auto position-relative" style="max-width: 350px; z-index: 1010;">
                            <div class="flex-grow-1 position-relative">
                                <input type="text" name="searchQuery" class="form-control form-control-sm" 
                                       id="navSearchInput"
                                       placeholder="Search candidates and jobs..." 
                                       aria-label="Search candidates and jobs"
                                       autocomplete="off" />
                                <div class="position-absolute w-100 bg-white border border-top-0 rounded-bottom shadow-sm" 
                                     id="navSearchResults" 
                                     style="display: none; max-height: 400px; overflow-y: auto; top: 100%; left: 0; right: 0;">
                                </div>
                            </div>
                            <button class="btn btn-outline-light btn-sm ms-2" type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </form>
                        <div class="dropdown ms-3 d-flex align-items-center">
                            <button class="user-avatar dropdown-toggle" type="button" id="userMenuToggle"
                                    data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
                                @_initials
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuToggle">
                                <li><h6 class="dropdown-header text-truncate" style="max-width:220px;">
                                    <i class="fas fa-user me-1"></i>@(User.Identity?.Name ?? "User")
                                </h6></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Admin" asp-action="Profile">
                                        <i class="fas fa-id-card me-2"></i>My Profile
                                    </a>
                                </li>
                                <li>
                                    <form asp-action="Logout" asp-controller="Account" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="fas fa-sign-out-alt me-2"></i>Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="wr-footer border-top mt-5 py-4 text-white">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h6 class="fw-bold"><i class="fas fa-briefcase me-2"></i>WiseRecruiter</h6>
                    <p class="text-white-50 small">Do you have bold ideas and a passion to build bold products?</p>
                </div>
                <div class="col-md-6 text-end">
                    <p class="small text-white-50">&copy; 2026 WiseRecruiter. All rights reserved.</p>
                    <p><a href="@Url.Action("Privacy", "Home")" class="text-white-50 small">Privacy Policy</a></p>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Live search autocomplete for navbar — searches candidates + jobs
        document.getElementById('navSearchInput')?.addEventListener('input', async function(e) {
            const searchQuery = e.target.value.trim();
            const resultsContainer = document.getElementById('navSearchResults');
            
            if (!searchQuery) {
                resultsContainer.style.display = 'none';
                return;
            }
            
            try {
                const response = await fetch(`@Url.Action("Search", "Admin")?query=${encodeURIComponent(searchQuery)}`);
                const results = await response.json();
                
                const candidates = results.filter(r => r.type === 'Candidate');
                const jobs = results.filter(r => r.type === 'Job');
                
                if (results.length === 0) {
                    resultsContainer.innerHTML = '<div class="p-3 text-muted text-center small">No results found</div>';
                } else {
                    let html = '';
                    if (candidates.length) {
                        html += '<div class="px-3 pt-2 pb-1 border-bottom"><small class="text-muted fw-bold" style="font-size:0.7rem;letter-spacing:0.05em;">CANDIDATES</small></div>';
                        html += candidates.map(r =>
                            `<a href="@Url.Action("CandidateDetails", "Admin")/${r.id}" 
                               class="d-block px-3 py-2 text-decoration-none border-bottom hover-light-nav"
                               style="font-size:0.9rem;">
                                <i class="fas fa-user me-2" style="color:#7B3FF2;font-size:0.8rem;"></i>
                                <span style="color:#1E1765;">${r.displayText}</span>
                                ${r.subText ? `<small class="d-block text-muted ms-4 search-result-job" style="font-size:0.75rem;">${r.subText}</small>` : ''}
                             </a>`
                        ).join('');
                    }
                    if (jobs.length) {
                        html += '<div class="px-3 pt-2 pb-1 border-bottom"><small class="text-muted fw-bold" style="font-size:0.7rem;letter-spacing:0.05em;">JOBS</small></div>';
                        html += jobs.map(r =>
                            `<a href="@Url.Action("JobDetail", "Admin")/${r.id}" 
                               class="d-block px-3 py-2 text-decoration-none border-bottom hover-light-nav"
                               style="font-size:0.9rem;">
                                <i class="fas fa-briefcase me-2" style="color:#7B3FF2;font-size:0.8rem;"></i>
                                <span style="color:#1E1765;">${r.displayText}</span>
                             </a>`
                        ).join('');
                    }
                    resultsContainer.innerHTML = html;
                }
                
                resultsContainer.style.display = 'block';
            } catch (error) {
                console.error('Search failed:', error);
            }
        });
        
        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            const searchInput = document.getElementById('navSearchInput');
            const resultsContainer = document.getElementById('navSearchResults');
            
            if (searchInput && !searchInput.contains(e.target) && !resultsContainer?.contains(e.target)) {
                resultsContainer.style.display = 'none';
            }
        });
        
        // Add hover effect to dropdown items
        document.addEventListener('mouseover', function(e) {
            if (e.target.classList.contains('hover-light-nav') || e.target.closest('.hover-light-nav')) {
                e.target.closest('.hover-light-nav').style.backgroundColor = '#f8f9fa';
            }
        }, true);
        
        document.addEventListener('mouseout', function(e) {
            if (e.target.classList.contains('hover-light-nav') || e.target.closest('.hover-light-nav')) {
                e.target.closest('.hover-light-nav').style.backgroundColor = 'white';
            }
        }, true);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
