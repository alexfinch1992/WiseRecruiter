@{
    ViewData["Title"] = "Admin Login";
}

<div class="container py-5">
    <div class="row justify-content-center min-vh-80">
        <div class="col-md-5">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center py-4">
                    <i class="fas fa-lock fa-2x mb-3 text-white"></i>
                    <h3 class="fw-bold mb-0 text-white">WiseRecruiter Admin</h3>
                    <p class="small mt-2 text-white-50">Secure Access Portal</p>
                </div>
                <div class="card-body p-4">
                    <form method="post" asp-controller="Account" asp-action="Login">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>

                        <div class="mb-3">
                            <label for="username" class="form-label fw-bold"><i class="fas fa-user me-2"></i>Username</label>
                            <input type="text" id="username" name="username" class="form-control form-control-lg" placeholder="Enter your username" required />
                        </div>

                        <div class="mb-4">
                            <label for="password" class="form-label fw-bold"><i class="fas fa-key me-2"></i>Password</label>
                            <input type="password" id="password" name="password" class="form-control form-control-lg" placeholder="Enter your password" required />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold text-white" style="background: linear-gradient(135deg, #1E1765 0%, #7B3FF2 100%); border: none;"><i class="fas fa-sign-in-alt me-2"></i>Sign In</button>
                        </div>
                    </form>

                    <hr class="my-4" />

                    <div class="alert alert-info bg-light border-0" style="border-left: 4px solid #7B3FF2 !important;">
                        <p class="mb-2 font-weight-bold" style="color: #1E1765;">
                            <i class="fas fa-info-circle me-2"></i>Demo Credentials
                        </p>
                        <small class="d-block mb-1" style="color: #555;">
                            <strong>Username:</strong> <code>admin</code>
                        </small>
                        <small style="color: #555;">
                            <strong>Password:</strong> <code>admin123</code>
                        </small>
                    </div>

                    <div class="text-center mt-4">
                        <a href="/" class="btn btn-outline-primary"><i class="fas fa-arrow-left me-2"></i>Back to Home</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
