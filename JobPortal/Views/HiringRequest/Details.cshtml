@model JobPortal.Models.HiringRequest
@using JobPortal.Models

@{
    ViewData["Title"] = $"Hiring Request — {Model.RoleTitle}";
    Layout = "_Layout";

    var canEdit   = Model.Status is HiringRequestStatus.Draft or HiringRequestStatus.MoreInfoRequested;
    var canSubmit = Model.Status is HiringRequestStatus.Draft or HiringRequestStatus.MoreInfoRequested;
    var isStage1Pending = Model.Status == HiringRequestStatus.Submitted;
    var isStage2Pending = Model.Status == HiringRequestStatus.TalentLeadApproved;
    var isTerminal = Model.Status is HiringRequestStatus.ExecutiveApproved or HiringRequestStatus.Rejected;

    var isStage1Approver = User.IsInRole("Admin") || User.IsInRole("TalentLead");
    var isStage2Approver = User.IsInRole("Admin") || User.IsInRole("ApprovingExecutive");

    var statusClass = Model.Status switch
    {
        HiringRequestStatus.ExecutiveApproved  => "success",
        HiringRequestStatus.TalentLeadApproved => "info",
        HiringRequestStatus.Rejected           => "danger",
        HiringRequestStatus.Submitted          => "primary",
        HiringRequestStatus.MoreInfoRequested  => "warning",
        _                                      => "secondary"
    };
}

<div class="container py-4" style="max-width: 800px;">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left me-1"></i>All Requests
        </a>
        <div>
            <h4 class="fw-bold mb-0">@Model.RoleTitle</h4>
            <small class="text-muted">@Model.Department &middot; @Model.LevelBand &middot; @Model.Location</small>
        </div>
        <div class="ms-auto">
            <span class="badge bg-@statusClass">@Model.Status</span>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Status == HiringRequestStatus.MoreInfoRequested)
    {
        <div class="alert alert-warning mb-4">
            <strong>More information requested.</strong>
            Please review the notes in the activity timeline below, update your request, and resubmit.
        </div>
    }

    <!-- Request details -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-light fw-semibold">Request Details</div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4">Headcount</dt>
                <dd class="col-sm-8">@Model.Headcount</dd>

                <dt class="col-sm-4">Replacement</dt>
                <dd class="col-sm-8">
                    @(Model.IsReplacement ? "Yes" : "No")
                    @if (Model.IsReplacement && !string.IsNullOrEmpty(Model.ReplacementReason))
                    {
                        <span class="text-muted ms-2">— @Model.ReplacementReason</span>
                    }
                </dd>

                @if (!string.IsNullOrEmpty(Model.Justification))
                {
                    <dt class="col-sm-4">Justification</dt>
                    <dd class="col-sm-8" style="white-space: pre-line;">@Model.Justification</dd>
                }
            </dl>
        </div>
    </div>

    <!-- Activity timeline -->
    @if (Model.Comments.Any())
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-light fw-semibold">Activity Timeline</div>
            <div class="card-body pb-2">
                <div class="timeline">
                    @foreach (var comment in Model.Comments)
                    {
                        var (badgeClass, actionLabel) = comment.Action switch
                        {
                            "Submitted"          => ("primary",  "Submitted"),
                            "TalentLeadApproved" => ("success",  "Approved — Talent Lead"),
                            "ExecutiveApproved"  => ("success",  "Approved — Executive"),
                            "Rejected"           => ("danger",   "Rejected"),
                            "MoreInfoRequested"  => ("warning",  "More Info Requested"),
                            _                    => ("secondary", comment.Action)
                        };

                        <div class="d-flex gap-3 mb-3">
                            <div class="pt-1 flex-shrink-0">
                                <span class="badge rounded-pill bg-@badgeClass" style="min-width: 140px;">@actionLabel</span>
                            </div>
                            <div class="flex-grow-1">
                                <div class="small text-muted mb-1">
                                    <strong>@(comment.User?.FullName ?? comment.User?.UserName ?? "Unknown")</strong>
                                    &middot;
                                    @comment.CreatedUtc.ToString("d MMM yyyy HH:mm") UTC
                                </div>
                                @if (!string.IsNullOrWhiteSpace(comment.Comment))
                                {
                                    <div class="text-body small" style="white-space: pre-line;">@comment.Comment</div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Actions -->
    @if (!isTerminal)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light fw-semibold">Actions</div>
            <div class="card-body d-flex flex-wrap gap-2">

                @if (canEdit)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                        <i class="fas fa-edit me-1"></i>Edit
                    </a>
                }

                @if (canSubmit)
                {
                    <form asp-action="Submit" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-primary"
                                style="background: linear-gradient(135deg, #1E1765 0%, #7B3FF2 100%); border: none;">
                            <i class="fas fa-paper-plane me-1"></i>Submit for Review
                        </button>
                    </form>
                }

                @* Stage 1 — Talent Lead actions *@
                @if (isStage1Pending && isStage1Approver)
                {
                    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#approveStage1Modal">
                        <i class="fas fa-check me-1"></i>Approve
                    </button>
                    <button type="button" class="btn btn-warning text-dark" data-bs-toggle="modal" data-bs-target="#moreInfoStage1Modal">
                        <i class="fas fa-question-circle me-1"></i>Request More Info
                    </button>
                    <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#rejectStage1Modal">
                        <i class="fas fa-times me-1"></i>Reject
                    </button>
                }

                @* Stage 2 — Executive actions *@
                @if (isStage2Pending && isStage2Approver)
                {
                    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#approveStage2Modal">
                        <i class="fas fa-check me-1"></i>Approve
                    </button>
                    <button type="button" class="btn btn-warning text-dark" data-bs-toggle="modal" data-bs-target="#moreInfoStage2Modal">
                        <i class="fas fa-question-circle me-1"></i>Request More Info
                    </button>
                    <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#rejectStage2Modal">
                        <i class="fas fa-times me-1"></i>Reject
                    </button>
                }
            </div>
        </div>
    }
</div>

@* ── Stage 1 Modals ─────────────────────────────────────────────────────── *@

@if (isStage1Pending && isStage1Approver)
{
    <!-- Approve Stage 1 Modal -->
    <div class="modal fade" id="approveStage1Modal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="ApproveStage1" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fas fa-check-circle text-success me-2"></i>Approve — Talent Lead</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <label for="approveStage1Notes" class="form-label fw-semibold">Notes <span class="text-danger">*</span></label>
                        <textarea id="approveStage1Notes" name="notes" class="form-control" rows="4"
                                  placeholder="Explain your approval decision…" required></textarea>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Approve</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Request More Info Stage 1 Modal -->
    <div class="modal fade" id="moreInfoStage1Modal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="RequestMoreInfoStage1" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fas fa-question-circle text-warning me-2"></i>Request More Info</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <label for="moreInfoStage1Notes" class="form-label fw-semibold">What information is needed? <span class="text-danger">*</span></label>
                        <textarea id="moreInfoStage1Notes" name="notes" class="form-control" rows="4"
                                  placeholder="Describe what additional information or clarification is required…" required></textarea>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-warning text-dark">Request More Info</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Reject Stage 1 Modal -->
    <div class="modal fade" id="rejectStage1Modal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="RejectStage1" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fas fa-times-circle text-danger me-2"></i>Reject Request</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <label for="rejectStage1Notes" class="form-label fw-semibold">Reason for rejection <span class="text-danger">*</span></label>
                        <textarea id="rejectStage1Notes" name="notes" class="form-control" rows="4"
                                  placeholder="Explain why this request is being rejected…" required></textarea>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">Reject</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@* ── Stage 2 Modals ─────────────────────────────────────────────────────── *@

