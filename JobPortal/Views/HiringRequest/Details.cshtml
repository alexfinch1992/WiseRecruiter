{
    <!-- Approve Stage 2 Modal -->
    <div class="modal fade" id="approveStage2Modal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="ApproveStage2" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fas fa-check-circle text-success me-2"></i>Approve — Executive</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <label for="approveStage2Notes" class="form-label fw-semibold">Notes <span class="text-danger">*</span></label>
                        <textarea id="approveStage2Notes" name="notes" class="form-control" rows="4"
                                  placeholder="Explain your approval decision…" required></textarea>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Approve</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Request More Info Stage 2 Modal -->
    <div class="modal fade" id="moreInfoStage2Modal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="RequestMoreInfoStage2" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fas fa-question-circle text-warning me-2"></i>Request More Info</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <label for="moreInfoStage2Notes" class="form-label fw-semibold">What information is needed? <span class="text-danger">*</span></label>
                        <textarea id="moreInfoStage2Notes" name="notes" class="form-control" rows="4"
                                  placeholder="Describe what additional information or clarification is required…" required></textarea>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-warning text-dark">Request More Info</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Reject Stage 2 Modal -->
    <div class="modal fade" id="rejectStage2Modal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="RejectStage2" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fas fa-times-circle text-danger me-2"></i>Reject Request</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <label for="rejectStage2Notes" class="form-label fw-semibold">Reason for rejection <span class="text-danger">*</span></label>
                        <textarea id="rejectStage2Notes" name="notes" class="form-control" rows="4"
                                  placeholder="Explain why this request is being rejected…" required></textarea>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">Reject</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
