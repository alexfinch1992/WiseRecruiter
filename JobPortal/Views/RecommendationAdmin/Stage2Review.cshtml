@model JobPortal.Models.ViewModels.Stage2ReviewViewModel
@{
    ViewData["Title"] = "Stage 2 Review";
    var rec = Model.Recommendation;
}
<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-controller="RecommendationAdmin" asp-action="Pending"
           class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left me-1"></i>Back to Pending
        </a>
        <h2 class="fw-bold mb-0"><i class="fas fa-user-check me-2"></i>Stage 2 Review</h2>
    </div>

    <div class="row">
        <div class="col-12 col-lg-8">
            <div class="card mb-4">
                <div class="card-header fw-semibold bg-light">Candidate</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Name</dt>
                        <dd class="col-sm-9">@Model.CandidateName</dd>
                        <dt class="col-sm-3">Email</dt>
                        <dd class="col-sm-9">@Model.CandidateEmail</dd>
                        <dt class="col-sm-3">Role</dt>
                        <dd class="col-sm-9">@Model.JobTitle</dd>
                    </dl>
                </div>
            </div>

            @if (rec == null)
            {
                <div class="alert alert-warning">No Stage 2 recommendation has been submitted for this candidate.</div>
            }
            else
            {
                <div class="card mb-4">
                    <div class="card-header fw-semibold bg-light d-flex justify-content-between align-items-center">
                        <span>Stage 2 Recommendation</span>
                        <span class="badge @(rec.Status == JobPortal.Models.RecommendationStatus.Approved ? "bg-success" : "bg-secondary")">
                            @rec.Status
                        </span>
                    </div>
                    <div class="card-body">
                        <h6 class="text-muted text-uppercase fw-semibold" style="font-size:0.72rem;letter-spacing:.05em;">Summary / Notes</h6>
                        <p>@(rec.Summary ?? "—")</p>

                        <h6 class="text-muted text-uppercase fw-semibold mt-3" style="font-size:0.72rem;letter-spacing:.05em;">Strengths</h6>
                        <p>@(rec.ExperienceFit ?? "—")</p>

                        <h6 class="text-muted text-uppercase fw-semibold mt-3" style="font-size:0.72rem;letter-spacing:.05em;">Concerns</h6>
                        <p>@(rec.Concerns ?? "—")</p>

                        <h6 class="text-muted text-uppercase fw-semibold mt-3" style="font-size:0.72rem;letter-spacing:.05em;">Hire Recommendation</h6>
                        <p>
                            @if (rec.HireRecommendation == true)
                            {
                                <span class="badge bg-success"><i class="fas fa-thumbs-up me-1"></i>Yes — Recommend Hire</span>
                            }
                            else if (rec.HireRecommendation == false)
                            {
                                <span class="badge bg-danger"><i class="fas fa-thumbs-down me-1"></i>No — Do Not Hire</span>
                            }
                            else
                            {
                                <span class="text-muted">Not specified</span>
                            }
                        </p>
                    </div>
                </div>

                @if (rec.Status != JobPortal.Models.RecommendationStatus.Approved)
                {
                    <form asp-controller="RecommendationAdmin" asp-action="ApproveStage2"
                          asp-route-applicationId="@Model.ApplicationId" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label for="approvalFeedback" class="form-label fw-semibold">Manager Feedback <span class="text-muted fw-normal">(optional)</span></label>
                            <textarea id="approvalFeedback" name="approvalFeedback" class="form-control" rows="3"
                                      placeholder="Add any notes for the hiring team..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-check me-2"></i>Approve Stage 2 Recommendation
                        </button>
                    </form>
                }
                else
                {
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <p class="text-success fw-semibold mb-0">
                            <i class="fas fa-check-circle me-2"></i>Approved
                        </p>
                        @if (rec.ApprovedUtc.HasValue)
                        {
                            <span class="text-muted small">on @rec.ApprovedUtc.Value.ToString("dd MMM yyyy HH:mm") UTC</span>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(rec.ApprovalFeedback))
                    {
                        <div class="card border-success mt-2">
                            <div class="card-header bg-success bg-opacity-10 text-success fw-semibold py-2">
                                <i class="fas fa-comment-alt me-2"></i>Manager Feedback
                            </div>
                            <div class="card-body py-2">
                                <p class="mb-0">@rec.ApprovalFeedback</p>
                            </div>
                        </div>
                    }
                }
            }
        </div>
    </div>
</div>
