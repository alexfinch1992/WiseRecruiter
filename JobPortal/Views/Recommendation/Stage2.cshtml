@model JobPortal.Models.ViewModels.Stage2RecommendationViewModel
@using JobPortal.Models

@{
    var applicationId = (int)ViewData["ApplicationId"]!;
    var candidateName = ViewData["CandidateName"] as string ?? "Candidate";
    var jobTitle = ViewData["JobTitle"] as string ?? "Role";
    ViewData["Title"] = $"Stage 2 Recommendation — {candidateName}";
    Layout = "_Layout";
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-controller="Admin" asp-action="CandidateDetails" asp-route-id="@applicationId"
           class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left me-1"></i>Back to Candidate
        </a>
        <div>
            <h4 class="mb-0 fw-bold">Stage 2 Recommendation</h4>
            <small class="text-muted">@candidateName &mdash; @jobTitle</small>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header" style="background: linear-gradient(135deg, #1E1765 0%, #7B3FF2 100%);">
            <h5 class="fw-bold mb-0 text-white"><i class="fas fa-star-half-alt me-2"></i>Stage 2 Candidate Recommendation</h5>
        </div>
        <div class="card-body">
            <form asp-controller="Recommendation" asp-action="Stage2" asp-route-applicationId="@applicationId" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label class="form-label fw-semibold" for="Notes">Notes</label>
                    <textarea id="Notes" name="Notes" rows="5" class="form-control">@Model.Notes</textarea>
                    <div class="form-text text-muted">Overall summary for the hiring manager.</div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold" for="Strengths">Strengths</label>
                    <textarea id="Strengths" name="Strengths" rows="4" class="form-control">@Model.Strengths</textarea>
                    <div class="form-text text-muted">Key strengths and experience fit.</div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold" for="Concerns">Concerns</label>
                    <textarea id="Concerns" name="Concerns" rows="3" class="form-control">@Model.Concerns</textarea>
                    <div class="form-text text-muted">Concerns or areas to explore further.</div>
                </div>

                <div class="mb-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="HireRecommendation" name="HireRecommendation"
                               value="true"
                        @if (Model.HireRecommendation == true) { <text>checked</text> } />
                        <label class="form-check-label fw-semibold" for="HireRecommendation">
                            Recommend for hire
                        </label>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-4">
                    <a asp-controller="Admin" asp-action="CandidateDetails" asp-route-id="@applicationId"
                       class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary"
                            style="background: linear-gradient(135deg, #1E1765 0%, #7B3FF2 100%); border: none;">
                        <i class="fas fa-save me-1"></i>Save Recommendation
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
