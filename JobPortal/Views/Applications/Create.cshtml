@model JobPortal.Models.Application

@{
    ViewData["Title"] = "Apply for Job";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Submit Your Application</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <input type="hidden" asp-for="JobId" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Full Name *</label>
                            <input asp-for="Name" class="form-control form-control-lg" placeholder="Enter your full name" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Email Address</label>
                            <input asp-for="Email" type="email" class="form-control form-control-lg" placeholder="Enter your email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="City" class="form-label fw-bold">City *</label>
                            <input asp-for="City" class="form-control form-control-lg" placeholder="Enter your city" />
                            <span asp-validation-for="City" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label for="resume" class="form-label fw-bold">Resume Upload *</label>
                            <input type="file" id="resume" name="resume" class="form-control form-control-lg" accept=".pdf,.docx,.txt" required />
                            <small class="text-muted">Accepted formats: PDF, DOCX, TXT (Max 5MB)</small>
                            <span class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-controller="Job" asp-action="Index" class="btn btn-secondary me-2">Cancel</a>
                            <button type="submit" class="btn btn-success btn-lg">Submit Application</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<div>
    <a asp-action="Index">Back to List</a>
</div>
