@{
    ViewData["Title"] = "Home Page";
}

<div class="hero-section text-center py-5">
    <h1 class="display-3 fw-bold mb-3"><i class="fas fa-briefcase me-3"></i>WiseRecruiter</h1>
    <p class="lead mb-4">Do you have bold ideas and a passion to build bold products? </p>
    <div class="row justify-content-center">
        <div class="col-md-6">
            <a href="/Job" class="btn btn-primary btn-lg me-2"><i class="fas fa-search me-2"></i>Browse Jobs</a>
            <a href="/Admin" class="btn btn-success btn-lg"><i class="fas fa-lock me-2"></i>Admin Panel</a>
        </div>
    </div>
</div>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header">
                    <i class="fas fa-building me-2"></i>For WiseTech Admins
                </div>
                <div class="card-body text-center">
                    <i class="fas fa-user-tie fa-3x mb-3" style="color: #7B3FF2;"></i>
                    <h5 class="card-title">Post & Manage Opportunities</h5>
                    <p class="card-text">Post job openings, review applications, and manage your candidate pipeline all in one place.</p>
                    <a href="/Admin" class="btn btn-primary"><i class="fas fa-arrow-right me-2"></i>Go to Admin Panel</a>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header">
                    <i class="fas fa-user me-2"></i>For Candidates
                </div>
                <div class="card-body text-center">
                    <i class="fas fa-briefcase fa-3x mb-3" style="color: #7B3FF2;"></i>
                    <h5 class="card-title">Find Your Dream Job</h5>
                    <p class="card-text">Browse available positions, submit applications with your resume, and track your progress.</p>
                    <a href="/Job" class="btn btn-primary"><i class="fas fa-arrow-right me-2"></i>Browse Jobs</a>
                </div>
            </div>
        </div>
    </div>
</div>
