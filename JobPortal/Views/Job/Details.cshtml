@model JobPortal.Models.Job

@{
    ViewData["Title"] = "Job Details";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">@Model.Title</h4>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <h6 class="text-muted">Description</h6>
                        <p class="card-text">@Model.Description</p>
                    </div>

                    <div class="alert alert-light border">
                        <strong>Job ID:</strong> @Model.Id
                    </div>

                    <div class="mb-3">
                        <strong>Scorecard Template:</strong>
                        @if (Model.ScorecardTemplate != null)
                        {
                            <a asp-controller="AdminSettings" asp-action="EditTemplate" asp-route-id="@Model.ScorecardTemplate.Id">@Model.ScorecardTemplate.Name</a>
                        }
                        else
                        {
                            <span>None assigned</span>
                        }
                    </div>
                </div>
                <div class="card-footer bg-white border-top">
                    <a asp-controller="Applications" asp-action="Create" asp-route-jobId="@Model.Id" class="btn btn-success btn-lg">Apply Now</a>
                    <a asp-action="Index" class="btn btn-secondary">Back to Jobs</a>
                </div>
            </div>
        </div>
    </div>
</div>
