@model IEnumerable<JobPortal.Models.Job>

@{
    ViewData["Title"] = "Browse Jobs";
}

<div class="container py-5">
    <div class="row mb-5">
        <div class="col-md-8">
            <h1 class="fw-bold mb-2"><i class="fas fa-briefcase me-3"></i>Available Positions</h1>
            <p class="text-muted lead">Find and apply for exciting job opportunities</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="/" class="btn btn-outline-primary"><i class="fas fa-arrow-left me-2"></i>Back to Home</a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var job in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card job-card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title job-title"><i class="fas fa-star me-2" style="color: #FFB600;"></i>@Html.DisplayFor(model => job.Title)</h5>
                            <div class="mb-3">
                                <small class="badge badge-primary">Job ID: @job.Id</small>
                            </div>
                            <p class="card-text text-muted">@{
                                var description = job.Description;
                                if (description?.Length > 100)
                                {
                                    @Html.Raw(description.Substring(0, 100) + "...")
                                }
                                else
                                {
                                    @description
                                }
                            }</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted"><i class="fas fa-calendar-alt me-1"></i>Posted on</small>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top">
                            <a asp-action="Details" asp-route-id="@job.Id" class="btn btn-primary w-100"><i class="fas fa-arrow-right me-2"></i>View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5 rounded">
            <i class="fas fa-inbox fa-3x mb-3" style="color: #7B3FF2;"></i>
            <h5 class="fw-bold mt-3">No Jobs Available</h5>
            <p class="text-muted">Please check back later for new job opportunities</p>
            <a href="/" class="btn btn-primary mt-3"><i class="fas fa-arrow-left me-2"></i>Back to Home</a>
        </div>
    }
</div>
