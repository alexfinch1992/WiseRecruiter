@model JobPortal.Models.ViewModels.ManageTeamViewModel
@{
    ViewData["Title"] = "Manage Team";
}


<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0"><i class="fas fa-users-cog me-2"></i>Manage Team</h2>
        <p class="text-muted small mt-1 mb-0">
            Control which jobs each Hiring Manager can see. Changes are saved immediately.
        </p>
    </div>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createUserModal">
        <i class="fas fa-user-plus me-1"></i>Create User
    </button>
</div>

<!-- Create User Modal -->
<div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createUserModalLabel"><i class="fas fa-user-plus me-2"></i>Create New User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="create-user-alert" class="alert d-none" role="alert"></div>
                <div class="mb-3">
                    <label for="cu-fullname" class="form-label">Full Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="cu-fullname" placeholder="e.g. Jane Smith" maxlength="100" />
                </div>
                <div class="mb-3">
                    <label for="cu-email" class="form-label">Email Address <span class="text-danger">*</span></label>
                    <input type="email" class="form-control" id="cu-email" placeholder="jane.smith@company.com" maxlength="200" />
                </div>
                <div class="mb-3">
                    <label for="cu-role" class="form-label">Role <span class="text-danger">*</span></label>
                    <select class="form-select" id="cu-role">
                        <option value="">-- Select a role --</option>
                        <option value="Admin">Admin</option>
                        <option value="Recruiter">Recruiter</option>
                        <option value="HiringManager">Hiring Manager</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="cu-submit-btn">
                    <span id="cu-spinner" class="spinner-border spinner-border-sm me-1 d-none" role="status" aria-hidden="true"></span>
                    Create User
                </button>
            </div>
        </div>
    </div>
</div>

@if (!Model.Users.Any())
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i>
        No team members found. Use the <strong>Create User</strong> button above to add one.
    </div>
}
else if (!Model.AllJobs.Any())
{
    <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle me-2"></i>
        No jobs exist yet.
    </div>
}
else
{
    <!-- Compact summary table: one row per user, no horizontal scroll -->
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Role</th>
                    <th class="text-center">Jobs Assigned</th>
                    <th class="text-center" style="width:140px">Access</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    var assignedTitles = Model.AllJobs
                        .Where(j => user.AssignedJobIds.Contains(j.Id))
                        .Select(j => j.Title);
                    <tr>
                        <td class="fw-medium">@user.FullName</td>
                        <td><span class="badge role-badge @(user.Role == "Admin" ? "bg-danger" : user.Role == "Recruiter" ? "bg-success" : "bg-primary")">@user.Role</span></td>
                        <td class="text-center">
                            @if (user.AssignedJobIds.Any())
                            {
                                <span class="badge bg-success rounded-pill job-count-badge"
                                      title="@string.Join(", ", assignedTitles)">
                                    @user.AssignedJobIds.Count
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill job-count-badge">0</span>
                            }
                        </td>
                        <td class="text-center">
                            <button type="button"
                                    class="btn btn-sm btn-outline-primary manage-access-btn"
                                    data-user-id="@user.UserId"
                                    data-user-name="@user.FullName"
                                    data-assigned-ids="@System.Text.Json.JsonSerializer.Serialize(user.AssignedJobIds)"
                                    data-bs-toggle="modal"
                                    data-bs-target="#manageAccessModal">
                                <i class="fas fa-key me-1"></i>Manage Access
                            </button>
                            <button type="button"
                                    class="btn btn-sm btn-outline-danger delete-user-btn ms-1"
                                    data-user-id="@user.UserId"
                                    data-user-name="@user.FullName">
                                <i class="fas fa-trash me-1"></i>Delete
                            </button>
                            <button type="button"
                                    class="btn btn-sm btn-outline-warning login-as-btn ms-1"
                                    data-user-id="@user.UserId"
                                    data-user-name="@user.FullName">
                                <i class="fas fa-sign-in-alt me-1"></i>Login as
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Manage Access Modal (shared, populated by JS) -->
<div class="modal fade" id="manageAccessModal" tabindex="-1" aria-labelledby="manageAccessLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="manageAccessLabel">
                    <i class="fas fa-key me-2"></i>Manage Job Access — <span id="ma-username"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="ma-alert" class="alert d-none" role="alert"></div>
                <div class="mb-3">
                    <input type="text" id="ma-search" class="form-control"
                           placeholder="Search jobs…" autocomplete="off" />
                </div>
                <div id="ma-job-list" class="overflow-auto" style="max-height:420px;">
                    <!-- Populated by JS -->
                </div>
                <p id="ma-no-results" class="text-center text-muted small mt-2 d-none">No jobs match your search.</p>
            </div>
            <div class="modal-footer justify-content-between">
                <small class="text-muted" id="ma-count-label"></small>
                <div>
                    <button type="button" class="btn btn-secondary me-1" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="ma-save-btn">
                        <span id="ma-spinner" class="spinner-border spinner-border-sm me-1 d-none" role="status" aria-hidden="true"></span>
                        Save Changes
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

{{!-- Hidden form just to expose the CSRF token to vanilla JS --}}
<form id="csrf-form" style="display:none">@Html.AntiForgeryToken()</form>

<div id="save-status" class="position-fixed bottom-0 end-0 p-3" style="z-index:1080;display:none">
    <div id="save-toast" class="toast text-white border-0 show" role="status">
        <div class="toast-body" id="save-toast-msg">Saved</div>
    </div>
</div>

@section Scripts {
<script>
    const csrfToken = document.querySelector('#csrf-form input[name="__RequestVerificationToken"]').value;

    // ── All jobs from server ───────────────────────────────────────
    const allJobs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.AllJobs.Select(j => new { id = j.Id, title = j.Title })
    ));

    // ── Create User Modal ──────────────────────────────────────────
    document.getElementById('cu-submit-btn').addEventListener('click', async function () {
        const fullName = document.getElementById('cu-fullname').value.trim();
        const email    = document.getElementById('cu-email').value.trim();
        const role     = document.getElementById('cu-role').value;
        const alertEl  = document.getElementById('create-user-alert');

        alertEl.className = 'alert d-none';
        alertEl.textContent = '';

        if (!fullName || !email || !role) {
            alertEl.className = 'alert alert-warning';
            alertEl.textContent = 'Please fill in all fields.';
            return;
        }

        const btn = this;
        const spinner = document.getElementById('cu-spinner');
        btn.disabled = true;
        spinner.classList.remove('d-none');

        try {
            const res = await fetch('@Url.Action("CreateUser", "AdminSettings")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': csrfToken },
                body: new URLSearchParams({ fullName, email, role })
            });
            const data = await res.json();
            if (res.ok) {
                window.location.reload();
            } else {
                alertEl.className = 'alert alert-danger';
                alertEl.textContent = data.error || 'An error occurred.';
            }
        } catch {
            alertEl.className = 'alert alert-danger';
            alertEl.textContent = 'Network error — please try again.';
        } finally {
            btn.disabled = false;
            spinner.classList.add('d-none');
        }
    });

    document.getElementById('createUserModal').addEventListener('hidden.bs.modal', function () {
        document.getElementById('cu-fullname').value = '';
        document.getElementById('cu-email').value    = '';
        document.getElementById('cu-role').value     = '';
        const alertEl = document.getElementById('create-user-alert');
        alertEl.className   = 'alert d-none';
        alertEl.textContent = '';
    });

    // ── Delete User ────────────────────────────────────────────────
    document.querySelectorAll('.delete-user-btn').forEach(function (btn) {
        btn.addEventListener('click', async function () {
            const userId   = this.dataset.userId;
            const userName = this.dataset.userName;
            if (!confirm(`Delete "${userName}"? This action cannot be undone.`)) return;

            try {
                const res = await fetch('@Url.Action("DeleteUser", "AdminSettings")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': csrfToken },
                    body: new URLSearchParams({ userId })
                });
                const data = await res.json();
                if (res.ok) {
                    window.location.reload();
                } else {
                    alert(data.error || 'Delete failed — please try again.');
                }
            } catch {
                alert('Network error — please try again.');
            }
        });
    });

    // ── Manage Access Modal ────────────────────────────────────────
    let activeUserId = null;

    document.querySelectorAll('.manage-access-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            activeUserId = this.dataset.userId;
            const assignedIds = JSON.parse(this.dataset.assignedIds || '[]');

            document.getElementById('ma-username').textContent = this.dataset.userName;
            document.getElementById('ma-search').value = '';
            document.getElementById('ma-alert').className = 'alert d-none';

            renderJobList(allJobs, assignedIds);
        });
    });

    function renderJobList(jobs, assignedIds) {
        const list = document.getElementById('ma-job-list');
        list.innerHTML = jobs.map(j => `
            <div class="form-check border-bottom py-2 px-3 job-item">
                <input class="form-check-input" type="checkbox" value="${j.id}"
                       id="job-cb-${j.id}" ${assignedIds.includes(j.id) ? 'checked' : ''}>
                <label class="form-check-label w-100" for="job-cb-${j.id}">${j.title}</label>
            </div>`
        ).join('');
        updateCount();
    }

    function getCheckedJobIds() {
        return Array.from(document.querySelectorAll('#ma-job-list input[type=checkbox]:checked'))
                    .map(cb => parseInt(cb.value, 10));
    }

    function updateCount() {
        const n = getCheckedJobIds().length;
        document.getElementById('ma-count-label').textContent =
            n === 0 ? 'No jobs assigned' : `${n} job${n === 1 ? '' : 's'} assigned`;
    }

    document.getElementById('ma-job-list').addEventListener('change', updateCount);

    // Search / filter
    document.getElementById('ma-search').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        const items = document.querySelectorAll('#ma-job-list .job-item');
        let visible = 0;
        items.forEach(function (item) {
            const label = item.querySelector('label').textContent.toLowerCase();
            const match = !q || label.includes(q);
            item.style.display = match ? '' : 'none';
            if (match) visible++;
        });
        document.getElementById('ma-no-results').classList.toggle('d-none', visible > 0);
    });

    // Save
    document.getElementById('ma-save-btn').addEventListener('click', async function () {
        if (!activeUserId) return;

        const alertEl = document.getElementById('ma-alert');
        alertEl.className = 'alert d-none';

        const saveBtn = this;
        const spinner = document.getElementById('ma-spinner');
        saveBtn.disabled = true;
        spinner.classList.remove('d-none');

        const jobIds = getCheckedJobIds();
        const body = new URLSearchParams({ userId: activeUserId });
        jobIds.forEach(id => body.append('jobIds', id));

        try {
            const res = await fetch('@Url.Action("UpdateJobAccess", "AdminSettings")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': csrfToken },
                body: body.toString()
            });

            if (res.ok) {
                showToast('✓ Access updated', 'bg-success');
                // Update the badge in the table row
                const rowBtn  = document.querySelector(`.manage-access-btn[data-user-id="${activeUserId}"]`);
                if (rowBtn) {
                    rowBtn.dataset.assignedIds = JSON.stringify(jobIds);
                    const badge = rowBtn.closest('tr').querySelector('.job-count-badge');
                    if (badge) {
                        badge.textContent = jobIds.length;
                        badge.className = 'badge rounded-pill ' + (jobIds.length ? 'bg-success' : 'bg-secondary');
                    }
                }
                bootstrap.Modal.getInstance(document.getElementById('manageAccessModal')).hide();
            } else {
                alertEl.className = 'alert alert-danger';
                alertEl.textContent = 'Failed to save — please try again.';
            }
        } catch {
            alertEl.className = 'alert alert-danger';
            alertEl.textContent = 'Network error — please try again.';
        } finally {
            saveBtn.disabled = false;
            spinner.classList.add('d-none');
        }
    });

    document.getElementById('manageAccessModal').addEventListener('hidden.bs.modal', function () {
        activeUserId = null;
    });

    function showToast(msg, cls) {
        const wrap  = document.getElementById('save-status');
        const toast = document.getElementById('save-toast');
        toast.className = 'toast text-white border-0 show ' + cls;
        document.getElementById('save-toast-msg').textContent = msg;
        wrap.style.display = 'block';
        setTimeout(function () { wrap.style.display = 'none'; }, 2500);
    }

    // ── Login As User ──────────────────────────────────────────────
    document.querySelectorAll('.login-as-btn').forEach(function (btn) {
        btn.addEventListener('click', async function () {
            const userId   = this.dataset.userId;
            const userName = this.dataset.userName;
            if (!confirm(`Switch to "${userName}"? You will be signed out of your current session.`)) return;

            try {
                const res = await fetch('@Url.Action("LoginAs", "AdminSettings")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': csrfToken },
                    body: new URLSearchParams({ userId })
                });
                if (res.ok) {
                    location.href = '/Admin';
                } else {
                    const data = await res.json();
                    alert(data.error || 'Failed to switch user.');
                }
            } catch {
                alert('Network error — please try again.');
            }
        });
    });
</script>
}
