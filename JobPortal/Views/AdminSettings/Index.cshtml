@model IEnumerable<JobPortal.Models.Facet>

@{
    ViewData["Title"] = "Settings - Scorecard Facets";
    var templateNamesByFacetId = ViewBag.TemplateNamesByFacetId as Dictionary<int, List<string>> ?? new Dictionary<int, List<string>>();
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1"><i class="fas fa-sliders-h me-2"></i>Scorecard Facets</h1>
            <p class="text-muted mb-0">Manage active and inactive scorecard facets.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Templates" class="btn btn-outline-primary">Manage Templates</a>
            <a asp-action="Create" class="btn btn-success"><i class="fas fa-plus me-2"></i>New Facet</a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Order</th>
                        <th>Used In</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var facet in Model)
                        {
                            <tr>
                                <td>@facet.Name</td>
                                <td>—</td>
                                <td>
                                    @if (templateNamesByFacetId.TryGetValue(facet.Id, out var templateNames) && templateNames.Any())
                                    {
                                        @string.Join(", ", templateNames)
                                    }
                                    else
                                    {
                                        <span class="text-muted">(Not used)</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@facet.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">No facets configured.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>