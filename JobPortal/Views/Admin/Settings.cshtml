@{
    ViewData["Title"] = "Settings";
}
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12 col-md-6">
            <h2 class="fw-bold mb-4"><i class="fas fa-sliders-h me-2"></i>Settings</h2>

            <h5 class="mt-4 text-muted fw-semibold text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.05em;">Evaluation</h5>
            <div class="list-group mb-3">
                <a asp-controller="AdminSettings" asp-action="Templates" class="list-group-item list-group-item-action">
                    <i class="fas fa-clipboard-list me-2"></i>Scorecards
                </a>
                <a asp-controller="RecommendationAdmin" asp-action="Pending" class="list-group-item list-group-item-action">
                    <i class="fas fa-inbox me-2"></i>Pending Recommendations
                </a>
                <a asp-controller="AdminSettings" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="fas fa-tags me-2"></i>Facets
                </a>
            </div>

            <h5 class="mt-4 text-muted fw-semibold text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.05em;">Communications</h5>
            <div class="list-group mb-3">
                <a asp-controller="Email" asp-action="EmailTemplates" class="list-group-item list-group-item-action">
                    <i class="fas fa-envelope me-2"></i>Communication Templates
                    <small class="text-muted d-block">Manage automated screening invites and offer letters.</small>
                </a>
            </div>

            <h5 class="mt-4 text-muted fw-semibold text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.05em;">People</h5>
            <div class="list-group mb-3">
                <a asp-controller="AdminSettings" asp-action="ManageTeam" class="list-group-item list-group-item-action">
                    <i class="fas fa-users-cog me-2"></i>Manage Team
                    <small class="text-muted d-block">Create users &amp; control job visibility</small>
                </a>
            </div>
        </div>
    </div>
</div>
