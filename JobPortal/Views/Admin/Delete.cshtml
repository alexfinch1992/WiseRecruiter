@model JobPortal.Models.Job

@{
    ViewData["Title"] = "Delete Job";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Delete Job</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <strong>Warning!</strong> This action cannot be undone.
                    </div>

                    <div class="mb-4">
                        <h5>Job Title</h5>
                        <p>@Html.DisplayFor(model => model.Title)</p>
                    </div>

                    <div class="mb-4">
                        <h5>Description</h5>
                        <p>@Html.DisplayFor(model => model.Description)</p>
                    </div>

                    <p class="text-danger">
                        <strong>Are you sure you want to delete this job posting?</strong>
                    </p>

                    <form asp-controller="Job" asp-action="Delete" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="Id" />

                        <button type="submit" class="btn btn-danger btn-lg">
                            Yes, Delete
                        </button>
                    </form>
                    <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary btn-lg">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>
