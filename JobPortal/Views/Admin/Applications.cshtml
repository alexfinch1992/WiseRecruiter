@model IEnumerable<JobPortal.Models.Job>

@{
    ViewData["Title"] = "View Applications";
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>Candidate Applications</h1>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="Index" class="btn btn-secondary">Back to Jobs</a>
        </div>
    </div>

    @if (Model.Any())
    {
        @foreach (var job in Model)
        {
            @if (job.Applications.Any())
            {
                <div class="card mb-4 shadow">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            @job.Title
                            <span class="badge bg-light text-primary float-end">@job.Applications.Count() Application(s)</span>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Candidate Name</th>
                                        <th>Email</th>
                                        <th>City</th>
                                        <th>Resume</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var application in job.Applications.OrderByDescending(a => a.Id))
                                    {
                                        <tr>
                                            <td><strong>@application.Name</strong></td>
                                            <td>@(string.IsNullOrEmpty(application.Email) ? "N/A" : application.Email)</td>
                                            <td>@application.City</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(application.ResumePath))
                                                {
                                                    <a asp-action="DownloadResume" asp-route-id="@application.Id" class="btn btn-sm btn-outline-primary">Download Resume</a>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No Resume</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        }
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <h5>No applications yet</h5>
            <p>Applications from candidates will appear here once they apply for your jobs.</p>
        </div>
    }
</div>
