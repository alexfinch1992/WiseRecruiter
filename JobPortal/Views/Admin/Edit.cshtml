@model JobPortal.Models.ViewModels.JobEditViewModel

@{
    ViewData["Title"] = "Edit Job";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Edit Job</h4>
                </div>
                <div class="card-body">
                    <form asp-controller="Admin" asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <input type="hidden" asp-for="Job.Id" />

                        <div class="mb-3">
                            <label asp-for="Job.Title" class="form-label fw-bold">Job Title *</label>
                            <input asp-for="Job.Title" class="form-control form-control-lg" />
                            <span asp-validation-for="Job.Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Job.Description" class="form-label fw-bold">Job Description *</label>
                            <textarea asp-for="Job.Description" class="form-control" rows="6"></textarea>
                            <span asp-validation-for="Job.Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Job.ScorecardTemplateId" class="form-label fw-bold">Scorecard Template</label>
                            <select asp-for="Job.ScorecardTemplateId" asp-items="Model.ScorecardTemplates" class="form-select"></select>
                            <span asp-validation-for="Job.ScorecardTemplateId" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary me-2">Cancel</a>
                            <button type="submit" class="btn btn-warning btn-lg">Update Job</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
