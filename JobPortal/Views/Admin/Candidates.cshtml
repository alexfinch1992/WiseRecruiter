@{
    ViewData["Title"] = "Candidates";
}

@* React mount point. CandidateDashboard renders here after candidate-dashboard.js loads. *@
@* A spinner is shown as the initial content so there is no blank flash before JS boots.  *@
<div id="candidate-dashboard-root">
    <div class="text-center py-5">
        <div class="spinner-border" style="color: #7B3FF2;" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="text-muted mt-3 small">Loading candidates...</p>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/dist/candidate-dashboard.js"></script>
}