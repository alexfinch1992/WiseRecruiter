@model JobPortal.Models.ViewModels.CandidateSearchResultViewModel

@{
    ViewData["Title"] = "Candidates";
    var totalPages = (int)Math.Ceiling(Model.TotalCount / (double)Model.PageSize);
}

<div class="container-fluid py-5">
    <div class="row mb-4">
        <div class="col">
            <h1 class="fw-bold"><i class="fas fa-users me-3"></i>Candidates</h1>
            <p class="text-muted">@Model.TotalCount candidate@(Model.TotalCount != 1 ? "s" : "") found</p>
        </div>
    </div>

    <div class="row">
        <!-- React filter sidebar -->
        <div class="col-md-3">
            <div id="candidate-filter-root"></div>
        </div>

        <!-- Candidate list -->
        <div class="col-md-9">
            @if (!string.IsNullOrEmpty(Model.Params.SearchQuery) ||
                 (Model.Params.Locations != null && Model.Params.Locations.Any()) ||
                 (Model.Params.JobIds != null && Model.Params.JobIds.Any()))
            {
                <div class="alert alert-info d-flex align-items-center mb-3" role="alert">
                    <i class="fas fa-filter me-2"></i>
                    <span>Filters active &mdash; showing @Model.TotalCount result@(Model.TotalCount != 1 ? "s" : "")</span>
                    <a href="@Url.Action("Candidates", "Admin")" class="btn btn-sm btn-outline-secondary ms-auto">
                        <i class="fas fa-times me-1"></i>Clear All
                    </a>
                </div>
            }

            <div id="candidates-list">
                @await Html.PartialAsync("_CandidatesListPartial", Model)
            </div>
        </div>
    </div>
</div>

<script>
    window.__candidateFilters = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
    {
        @params = Model.Params,
        locationFacets = Model.LocationFacets,
        jobFacets = Model.JobFacets
    }, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

    // Async sort/pagination handler
    document.getElementById("candidates-list")?.addEventListener("click", async function (e) {
        const link = e.target.closest(".sort-link, .page-link");
        if (!link) return;

        e.preventDefault();

        const container = document.getElementById("candidates-list");
        container.style.opacity = "0.5";

        try {
            const response = await fetch(link.href, {
                headers: { "X-Requested-With": "XMLHttpRequest" }
            });

            if (!response.ok) throw new Error();

            const html = await response.text();
            container.innerHTML = html;
            container.style.opacity = "1";

            history.pushState(null, "", link.href);
        } catch {
            window.location.href = link.href;
        }
    });

    // Handle browser back/forward
    window.addEventListener("popstate", async function () {
        const container = document.getElementById("candidates-list");
        if (!container) return;

        container.style.opacity = "0.5";
        try {
            const response = await fetch(location.href, {
                headers: { "X-Requested-With": "XMLHttpRequest" }
            });
            if (response.ok) {
                container.innerHTML = await response.text();
                container.style.opacity = "1";
            } else {
                location.reload();
            }
        } catch {
            location.reload();
        }
    });
</script>

@section Scripts {
    <script type="module" src="~/js/dist/candidate-filters.js" asp-append-version="true"></script>
}