@model JobPortal.Models.ViewModels.JobDetailViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    ViewData["Title"] = "Job Details";
    var Job = Model.Job;
}

<style>
    .stage-item {
        transition: all 0.3s ease-in-out;
    }
    
    .stage-item.moving-up {
        animation: slideUp 0.3s ease-in-out;
    }
    
    .stage-item.moving-down {
        animation: slideDown 0.3s ease-in-out;
    }
    
    @@keyframes slideUp {
        0% {
            transform: translateY(0);
            opacity: 1;
        }
        50% {
            opacity: 0.7;
        }
        100% {
            transform: translateY(-52px);
            opacity: 1;
        }
    }
    
    @@keyframes slideDown {
        0% {
            transform: translateY(0);
            opacity: 1;
        }
        50% {
            opacity: 0.7;
        }
        100% {
            transform: translateY(52px);
            opacity: 1;
        }
    }
</style>

<div class="container-fluid py-5">
    <div class="row mb-5">
        <div class="col-md-8">
            <h1 class="fw-bold mb-2"><i class="fas fa-briefcase me-3"></i>@Job.Title</h1>
            <p class="text-muted lead">Job ID: @Job.Id</p>
            <div class="d-flex align-items-center gap-2 mt-2">
                <span class="text-muted fw-semibold"><i class="fas fa-user-tie me-1"></i>Primary Recruiter:</span>
                @if (Job.OwnerUser != null)
                {
                    <span class="badge bg-primary">@Job.OwnerUser.FullName</span>
                }
                else
                {
                    <span class="text-muted fst-italic">Unassigned</span>
                }
            </div>
            @{
                var eligibleUsers = Model.ReviewerEligibleUsers as List<JobPortal.Models.ApplicationUser>
                                    ?? new List<JobPortal.Models.ApplicationUser>();
                var reviewerUserIds = (Job.JobUsers ?? new List<JobPortal.Models.JobUser>())
                    .Where(x => x.Role == "Reviewer")
                    .Select(x => x.UserId)
                    .ToHashSet();
            }
            @if (User.IsInRole("Admin") && eligibleUsers.Any())
            {
                <div class="mt-3">
                    <span class="text-muted fw-semibold"><i class="fas fa-user-check me-1"></i>Reviewers:</span>
                    <div class="d-flex flex-wrap gap-2 mt-1">
                        @foreach (var user in eligibleUsers)
                        {
                            <div class="form-check form-check-inline">
                                <input class="form-check-input reviewer-toggle"
                                       type="checkbox"
                                       id="reviewer-@user.Id"
                                       data-user-id="@user.Id"
                                       @(reviewerUserIds.Contains(user.Id) ? "checked" : "")
                                       onchange="toggleReviewer('@user.Id', this)" />
                                <label class="form-check-label" for="reviewer-@user.Id">@user.FullName</label>
                                <span class="save-indicator" style="display:none; margin-left:8px; color:green;">Saved</span>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                var reviewerNames = (Job.JobUsers ?? new List<JobPortal.Models.JobUser>())
                    .Where(x => x.Role == "Reviewer" && x.IsActive && x.User != null)
                    .Select(x => x.User.FullName)
                    .ToList();
                <div class="mt-3">
                    <span class="text-muted fw-semibold"><i class="fas fa-user-check me-1"></i>Reviewers:</span>
                    <span class="ms-1">@(reviewerNames.Any() ? string.Join(", ", reviewerNames) : "None assigned")</span>
                </div>
            }
            <div class="mt-3 d-flex align-items-center gap-2">
                <span class="text-muted fw-semibold"><i class="fas fa-bell me-1"></i>Alerts (Notifications):</span>
                <div id="job-alert-toggle-root" data-job-id="@Job.Id" data-csrf-token="@Antiforgery.GetAndStoreTokens(Context).RequestToken"></div>
            </div>
        </div>
        <div class="col-md-4 text-end">
            <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-primary"><i class="fas fa-arrow-left me-2"></i>Back to Jobs</a>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header">
                    <h5 class="fw-bold mb-0"><i class="fas fa-file-alt me-2"></i>Job Description</h5>
                </div>
                <div class="card-body">
                    <p class="card-text lead">@Job.Description</p>
                </div>
                <div class="card-footer bg-white border-top">
                    <div class="btn-group" role="group">
                        <a asp-action="Edit" asp-route-id="@Job.Id" class="btn btn-sm btn-outline-warning"><i class="fas fa-edit me-1"></i>Edit</a>
                        <a asp-controller="Job" asp-action="Delete" asp-route-id="@Job.Id" asp-route-returnUrl="@Url.Action("Index", "Admin")" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash me-1"></i>Delete</a>
                        <a asp-controller="Admin" asp-action="AddCandidate" asp-route-jobId="@Job.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-user-plus me-1"></i>Add Candidate</a>
                        @if (Model.HasApplicantsToReview)
                        {
                            <a asp-action="ResumeReview" asp-route-jobId="@Job.Id" class="btn btn-outline-primary">
                                Review Applicants
                            </a>
                        }
                        @* TEMP: seed button — remove before production *@
                        <form asp-action="SeedResumeReviewData" method="post" style="display:inline;">
                            <input type="hidden" name="jobId" value="@Job.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                Seed Test Applicants
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info">
                    <h5 class="fw-bold mb-0 text-white"><i class="fas fa-users me-2"></i>Candidates</h5>
                </div>
                <div class="card-body">
                    @{
                        var displayCount = Model.TotalCount;
                    }
                    <h2 class="display-4 fw-bold text-center" style="color: #1E1765;">
                        @displayCount
                    </h2>
                    <p class="text-center text-muted mt-3">
                        @(displayCount == 1 ? "Candidate" : "Candidates") in job
                    </p>
                    
                    @if (Job.Applications?.Any() == true)
                    {
                        <hr class="my-3" />
                        <div class="small">
                            @{
                                var stageSummary = Model.StageSummary as IReadOnlyList<JobPortal.Models.ViewModels.CandidateStageSummaryItem>
                                                   ?? new List<JobPortal.Models.ViewModels.CandidateStageSummaryItem>();
                            }
                            @foreach (var item in stageSummary)
                            {
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-truncate me-2">@item.StageName</span>
                                    <span class="badge bg-secondary" style="background-color: #7B3FF2 !important;">@item.Count</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @{
        var systemStageNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            "Applied", "Screen", "Offer", "Hired"
        };
        var stages = Job.Stages?
            .Where(s => !systemStageNames.Contains(s.Name))
            .OrderBy(s => s.Order)
            .ToList() ?? new List<JobStage>();
    }
    
    <!-- Interview Stages Management Section -->
    <div class="card shadow-sm border-0 mb-4">
            <div class="card-header d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #1E1765 0%, #7B3FF2 100%);">
                <h5 class="fw-bold mb-0 text-white"><i class="fas fa-tasks me-2"></i>Interview Stages</h5>
                <button
                    type="button"
                    class="btn btn-sm btn-light"
                    title="Expand/Collapse"
                    aria-label="Toggle interview stages"
                    aria-expanded="false"
                    onclick="toggleStagesCollapse(); this.setAttribute('aria-expanded', this.getAttribute('aria-expanded') === 'true' ? 'false' : 'true');">
                    <i class="fas fa-chevron-down" id="stagesCollapseIcon"></i>
                </button>
            </div>
            <div class="card-body" style="display: none;" id="stagesFilledView">
                @{
                    var _lockedClass = "d-flex align-items-center px-3 py-2 rounded mb-2";
                    var _lockedStyle = "border-left: 4px solid #adb5bd; background-color: #f8f9fa; opacity: 0.6;";
                }
                <!-- System stages: locked, non-editable -->
                <div class="@_lockedClass" style="@_lockedStyle">
                    <span class="flex-grow-1 fw-500 text-muted"><i class="fas fa-lock me-2" style="font-size:0.75rem;"></i>Applied</span>
                </div>
                <div class="@_lockedClass" style="@_lockedStyle">
                    <span class="flex-grow-1 fw-500 text-muted"><i class="fas fa-lock me-2" style="font-size:0.75rem;"></i>Screen</span>
                </div>
                @if (stages.Any())
                {
                    <div class="mb-0" id="stagesContainer">
                        @for (int i = 0; i < stages.Count; i++)
                        {
                            var stage = stages[i];
                            <div class="stage-item d-flex align-items-center px-3 py-2 rounded mb-2" data-stage-id="@stage.Id" data-stage-order="@i" style="border-left: 4px solid #7B3FF2; background-color: #f8f9fa;">
                                <span class="flex-grow-1 fw-500">@stage.Name</span>
                                <div class="btn-group btn-group-sm ms-2" role="group">
                                    @if (i > 0)
                                    {
                                        <button type="button" class="btn btn-outline-secondary" title="Move Up" onclick="moveStage(@stage.Id, @Job.Id, 'up', this)">
                                            <i class="fas fa-chevron-up"></i>
                                        </button>
                                    }
                                    @if (i < stages.Count - 1)
                                    {
                                        <button type="button" class="btn btn-outline-secondary" title="Move Down" onclick="moveStage(@stage.Id, @Job.Id, 'down', this)">
                                            <i class="fas fa-chevron-down"></i>
                                        </button>
                                    }
                                    <button type="button" class="btn btn-outline-danger" title="Remove Stage" onclick="removeStage(@stage.Id, @Job.Id, this)">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div id="stagesContainer"></div>
                }
                <!-- System stages: locked, non-editable -->
                <div class="@_lockedClass" style="@_lockedStyle">
                    <span class="flex-grow-1 fw-500 text-muted"><i class="fas fa-lock me-2" style="font-size:0.75rem;"></i>Offer</span>
                </div>
                <div class="@_lockedClass mb-3" style="@_lockedStyle">
                    <span class="flex-grow-1 fw-500 text-muted"><i class="fas fa-lock me-2" style="font-size:0.75rem;"></i>Hired</span>
                </div>

                <!-- Add New Stage Form -->
                <form method="post" asp-action="AddStage" class="d-flex gap-2 align-items-center">
                    <input type="hidden" name="jobId" value="@Job.Id" />
                    <input type="text" name="stageName" class="form-control form-control-sm" placeholder="Enter stage name (e.g., HR Review, Coding Test)" required />
                    <button type="submit" class="btn btn-sm btn-outline-success"><i class="fas fa-plus me-1"></i>Add Stage</button>
                    <span id="stageSaveStatus" style="display:none;" class="text-success small ms-1"><i class="fas fa-check me-1"></i>Saved</span>
                </form>
            </div>
            <div class="card-body" id="stagesCollapsedView">
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <span class="badge" style="background-color: #7B3FF2; font-size: 0.85rem;"><i class="fas fa-lock me-1"></i>Applied</span>
                    <span class="badge" style="background-color: #7B3FF2; font-size: 0.85rem;"><i class="fas fa-lock me-1"></i>Screen</span>
                    @foreach (var stage in stages)
                    {
                        <span class="badge" style="background-color: #7B3FF2; font-size: 0.85rem;">@stage.Name</span>
                    }
                    <span class="badge" style="background-color: #7B3FF2; font-size: 0.85rem;"><i class="fas fa-lock me-1"></i>Offer</span>
                    <span class="badge" style="background-color: #7B3FF2; font-size: 0.85rem;"><i class="fas fa-lock me-1"></i>Hired</span>
                </div>
            </div>
        </div>

    @if (Job.Applications?.Any() == true)
    {
        <div class="mb-4">
            <form asp-controller="Admin" asp-action="JobDetail" method="get" class="d-flex gap-2 mb-3" id="jobSearchForm">
                <input type="hidden" name="id" value="@Job.Id" />
                <div class="flex-grow-1 position-relative">
                    <input type="text" name="searchQuery" class="form-control" 
                           id="jobSearchInput"
                           placeholder="Search candidates by name or email..." 
                           value="@ViewData["SearchQuery"]"
                           autocomplete="off" />
                    <div class="position-absolute w-100 bg-white border border-top-0 rounded-bottom shadow-sm" 
                         id="jobSearchResults" 
                         style="display: none; max-height: 400px; overflow-y: auto; z-index: 1000; top: 100%;">
                    </div>
                </div>
                <button type="submit" class="btn btn-primary" style="background: linear-gradient(135deg, #1E1765 0%, #7B3FF2 100%); border: none;">
                    <i class="fas fa-search me-2"></i>Search
                </button>
                @if (!string.IsNullOrEmpty(ViewData["SearchQuery"]?.ToString()))
                {
                    <a asp-action="JobDetail" asp-route-id="@Job.Id" class="btn btn-outline-secondary">
                        <i class="fas fa-times me-2"></i>Clear
                    </a>
                }
            </form>

        </div>

        <div id="candidate-list">
            @await Html.PartialAsync("_CandidateListPartial", Model)
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5 rounded">
            <i class="fas fa-inbox fa-3x mb-3" style="color: #7B3FF2;"></i>
            <h5 class="fw-bold mt-3">No Candidates Yet</h5>
            <p class="text-muted">No one has applied for this position yet. Check back soon!</p>
        </div>
    }
</div>

<script>
// Async sort/pagination handler
document.addEventListener("click", async function (e) {
    const link = e.target.closest(".sort-link");
    if (!link) return;

    e.preventDefault();

    const container = document.getElementById("candidate-list");
    container.style.opacity = "0.5";

    try {
        const response = await fetch(link.href, {
            headers: { "X-Requested-With": "XMLHttpRequest" }
        });

        if (!response.ok) {
            window.location.href = link.href;
            return;
        }

        const html = await response.text();
        container.innerHTML = html;
        container.style.opacity = "1";

        // Update browser URL for back/forward navigation
        history.pushState(null, "", link.href);
    } catch {
        window.location.href = link.href;
    }
});

// Handle browser back/forward
window.addEventListener("popstate", async function () {
    const container = document.getElementById("candidate-list");
    if (!container) return;

    container.style.opacity = "0.5";
    try {
        const response = await fetch(location.href, {
            headers: { "X-Requested-With": "XMLHttpRequest" }
        });
        if (response.ok) {
            container.innerHTML = await response.text();
            container.style.opacity = "1";
        } else {
            location.reload();
        }
    } catch {
        location.reload();
    }
});

function showSavedIndicator() {
    const el = document.getElementById('stageSaveStatus');
    if (!el) return;
    el.style.display = 'inline';
    setTimeout(() => el.style.display = 'none', 2000);
}

async function moveStage(stageId, jobId, direction, button) {
    const container = document.getElementById('stagesContainer');
    const currentItem = container.querySelector(`[data-stage-id="${stageId}"]`);
    
    if (!currentItem) return;

    const currentOrder = parseInt(currentItem.getAttribute('data-stage-order'));
    const siblings = Array.from(container.querySelectorAll('.stage-item'));
    const nextOrder = direction === 'up' ? currentOrder - 1 : currentOrder + 1;
    const nextItem = siblings.find(s => parseInt(s.getAttribute('data-stage-order')) === nextOrder);

    if (!nextItem) return;

    // Disable button during animation
    button.disabled = true;

    try {
        const response = await fetch('@Url.Action("MoveStage")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: new URLSearchParams({
                stageId: stageId,
                jobId: jobId,
                direction: direction
            })
        });

        if (response.ok) {
            showSavedIndicator();
            // Add animation classes
            currentItem.classList.add(`moving-${direction}`);
            nextItem.classList.add(`moving-${direction === 'up' ? 'down' : 'up'}`);

            // Wait for animation to complete
            await new Promise(resolve => setTimeout(resolve, 300));

            // Swap the elements in DOM
            if (direction === 'up') {
                currentItem.parentNode.insertBefore(currentItem, nextItem);
            } else {
                nextItem.parentNode.insertBefore(nextItem, currentItem);
            }

            // Update order attributes
            currentItem.setAttribute('data-stage-order', nextOrder);
            nextItem.setAttribute('data-stage-order', currentOrder);

            // Remove animation classes
            currentItem.classList.remove(`moving-${direction}`);
            nextItem.classList.remove(`moving-${direction === 'up' ? 'down' : 'up'}`);

            // Re-render buttons for new positions
            renderStageButtons();
        } else {
            alert('Failed to move stage');
            button.disabled = false;
        }
    } catch (error) {
        console.error('Error:', error);
        alert('Error moving stage');
        button.disabled = false;
    }
}

async function removeStage(stageId, jobId, button) {
    if (!confirm('Remove this stage?')) return;

    const container = document.getElementById('stagesContainer');
    const stageItem = container.querySelector(`[data-stage-id="${stageId}"]`);

    if (!stageItem) return;

    button.disabled = true;

    try {
        const response = await fetch('@Url.Action("RemoveStage")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: new URLSearchParams({
                stageId: stageId,
                jobId: jobId
            })
        });

        if (response.ok) {
            showSavedIndicator();
            // Fade out animation
            stageItem.style.opacity = '0';
            stageItem.style.transform = 'scale(0.95)';
            
            await new Promise(resolve => setTimeout(resolve, 300));
            stageItem.remove();

            // Re-render buttons for remaining stages
            renderStageButtons();
        } else {
            alert('Failed to remove stage');
            button.disabled = false;
        }
    } catch (error) {
        console.error('Error:', error);
        alert('Error removing stage');
        button.disabled = false;
    }
}

function renderStageButtons() {
    const container = document.getElementById('stagesContainer');
    const items = Array.from(container.querySelectorAll('.stage-item'));
    
    items.forEach((item, index) => {
        const btnGroup = item.querySelector('.btn-group');
        const stageId = item.getAttribute('data-stage-id');
        const jobId = '@Job.Id';
        
        // Clear existing buttons
        btnGroup.innerHTML = '';
        
        // Add up button
        if (index > 0) {
            const upBtn = document.createElement('button');
            upBtn.type = 'button';
            upBtn.className = 'btn btn-outline-secondary';
            upBtn.title = 'Move Up';
            upBtn.innerHTML = '<i class="fas fa-chevron-up"></i>';
            upBtn.onclick = () => moveStage(stageId, jobId, 'up', upBtn);
            btnGroup.appendChild(upBtn);
        }
        
        // Add down button
        if (index < items.length - 1) {
            const downBtn = document.createElement('button');
            downBtn.type = 'button';
            downBtn.className = 'btn btn-outline-secondary';
            downBtn.title = 'Move Down';
            downBtn.innerHTML = '<i class="fas fa-chevron-down"></i>';
            downBtn.onclick = () => moveStage(stageId, jobId, 'down', downBtn);
            btnGroup.appendChild(downBtn);
        }
        
        // Add remove button
        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'btn btn-outline-danger';
        removeBtn.title = 'Remove Stage';
        removeBtn.innerHTML = '<i class="fas fa-times"></i>';
        removeBtn.onclick = () => removeStage(stageId, jobId, removeBtn);
        btnGroup.appendChild(removeBtn);
    });
}

function toggleStagesCollapse() {
    const filledView = document.getElementById('stagesFilledView');
    const collapsedView = document.getElementById('stagesCollapsedView');
    const icon = document.getElementById('stagesCollapseIcon');
    
    const isCollapsed = filledView.style.display === 'none';
    
    if (isCollapsed) {
        // Expand
        filledView.style.display = 'block';
        collapsedView.style.display = 'none';
        icon.classList.remove('fa-chevron-down');
        icon.classList.add('fa-chevron-up');
    } else {
        // Collapse
        filledView.style.display = 'none';
        collapsedView.style.display = 'block';
        icon.classList.remove('fa-chevron-up');
        icon.classList.add('fa-chevron-down');
    }
}

// Live search autocomplete for job candidates
document.getElementById('jobSearchInput')?.addEventListener('input', async function(e) {
    const searchQuery = e.target.value.trim();
    const resultsContainer = document.getElementById('jobSearchResults');
    
    if (!searchQuery) {
        resultsContainer.style.display = 'none';
        return;
    }
    
    try {
        const response = await fetch(`/Admin/JobDetailSearchApi?id=@Job.Id&searchQuery=${encodeURIComponent(searchQuery)}`);
        const results = await response.json();
        
        if (results.length === 0) {
            resultsContainer.innerHTML = '<div class="p-3 text-muted text-center">No candidates found</div>';
        } else {
            resultsContainer.innerHTML = results.map(candidate => `
                <a href="@Url.Action("Details", "Applications")?id=` + candidate.id + `" 
                   class="d-block p-3 text-decoration-none border-bottom hover-light"
                   style="transition: background-color 0.2s;">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-bold" style="color: #1E1765;">` + candidate.name + `</div>
                            <small class="text-muted">` + candidate.email + `</small>
                        </div>
                        <span class="badge" style="background: #7B3FF2; font-size: 0.75rem;">` + candidate.stage + `</span>
                    </div>
                </a>
            `).join('');
        }
        
        resultsContainer.style.display = 'block';
    } catch (error) {
        console.error('Search failed:', error);
        resultsContainer.innerHTML = '<div class="p-3 text-danger text-center">Search error</div>';
        resultsContainer.style.display = 'block';
    }
});

// Close dropdown when clicking outside
document.addEventListener('click', function(e) {
    const searchInput = document.getElementById('jobSearchInput');
    const resultsContainer = document.getElementById('jobSearchResults');
    
    if (searchInput && !searchInput.contains(e.target) && !resultsContainer?.contains(e.target)) {
        resultsContainer.style.display = 'none';
    }
});

// Add hover effect to dropdown items
document.addEventListener('mouseover', function(e) {
    if (e.target.classList.contains('hover-light') || e.target.closest('.hover-light')) {
        e.target.closest('.hover-light').style.backgroundColor = '#f8f9fa';
    }
}, true);

document.addEventListener('mouseout', function(e) {
    if (e.target.classList.contains('hover-light') || e.target.closest('.hover-light')) {
        e.target.closest('.hover-light').style.backgroundColor = 'white';
    }
}, true);

async function toggleReviewer(userId, checkbox) {
    try {
        const response = await fetch(`/api/jobs/@Job.Id/reviewers/${userId}`, {
            method: 'POST'
        });
        if (!response.ok) {
            alert('Failed to update reviewer');
            checkbox.checked = !checkbox.checked;
            return;
        }
        const indicator = checkbox.closest('.form-check').querySelector('.save-indicator');
        if (indicator) {
            indicator.style.display = 'inline';
            setTimeout(() => {
                indicator.style.display = 'none';
            }, 1500);
        }
    } catch (error) {
        alert('Failed to update reviewer');
        checkbox.checked = !checkbox.checked;
        console.error('Toggle reviewer error:', error);
    }
}
</script>
