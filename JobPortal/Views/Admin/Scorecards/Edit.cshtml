@model JobPortal.Services.Interfaces.ScorecardDetailDto

@{
    ViewData["Title"] = "Edit Scorecard";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Edit Scorecard</h2>
            <p class="text-muted mb-0">Scorecard #@Model.Id</p>
        </div>
        <a asp-action="ScorecardDetails" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Back to Details</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <form asp-action="EditScorecard" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <input asp-for="CandidateId" type="hidden" />

                @if (Model.Responses.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-3">
                            <thead>
                                <tr>
                                    <th>Facet</th>
                                    <th>Score</th>
                                    <th>Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var index = 0; index < Model.Responses.Count; index++)
                                {
                                    <tr>
                                        <td>
                                            @Model.Responses[index].FacetName
                                            <input asp-for="Responses[index].FacetName" type="hidden" />
                                            <span asp-validation-for="Responses[index].FacetName" class="text-danger d-block"></span>
                                        </td>
                                        <td>
                                            <input asp-for="Responses[index].Score" class="form-control" type="number" step="0.1" min="1" max="5" />
                                            <span asp-validation-for="Responses[index].Score" class="text-danger"></span>
                                        </td>
                                        <td>
                                            <textarea asp-for="Responses[index].Notes" class="form-control" rows="2"></textarea>
                                            <span asp-validation-for="Responses[index].Notes" class="text-danger"></span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">This scorecard currently has no responses. Saving will keep it empty.</p>
                }

                <button type="submit" class="btn btn-primary">Save Changes</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}