@model JobPortal.Services.Interfaces.ScorecardDetailDto

@{
    ViewData["Title"] = "Scorecard Details";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Scorecard Details</h2>
            <p class="text-muted mb-0">Scorecard #@Model.Id</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="text-end">
                <div class="small text-muted">Overall Average Score</div>
                <div class="fs-4 fw-semibold">@Model.AverageScore.ToString("0.0#")</div>
            </div>
            <a asp-action="EditScorecard" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edit</a>
            @if (!Model.IsArchived)
            {
                <form asp-action="ArchiveScorecard" asp-route-id="@Model.Id" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger"
                            onclick="return confirm('Archive this scorecard? It will be removed from analytics and the candidate view.')">
                        Archive
                    </button>
                </form>
            }
            else
            {
                <span class="badge bg-secondary ms-1">Archived</span>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.OverallRecommendation))
    {
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h5 class="card-title mb-2">Overall Recommendation</h5>
                <p class="mb-0" style="white-space: pre-wrap;">@Model.OverallRecommendation</p>
            </div>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body">
            @if (Model.Responses.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Facet</th>
                                <th>Score</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var response in Model.Responses)
                            {
                                <tr>
                                    <td>@response.FacetName</td>
                                    <td>@response.Score.ToString("0.0#")</td>
                                    <td>@(string.IsNullOrWhiteSpace(response.Notes) ? "-" : response.Notes)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">This scorecard has no responses yet.</p>
            }
        </div>
    </div>
</div>